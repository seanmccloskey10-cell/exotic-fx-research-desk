# Equity Research Desk — environment template
# Copy this file to `.env` (exact name, no `.txt` extension) before running.
# The dashboard works with ZERO keys — yfinance is the primary source and needs no key.
# Each key below is OPTIONAL and unlocks additional features when present.
# NEVER commit `.env` to git. `.gitignore` already excludes it.

# ------------------------------------------------------------------
# Finnhub (optional) — unlocks recent news + cleaner earnings calendar
# Free tier: 60 calls/minute. Sign up: https://finnhub.io/register
# ------------------------------------------------------------------
FINNHUB_API_KEY=

# ------------------------------------------------------------------
# Alpha Vantage (optional) — backup fundamentals if Finnhub is down
# Free tier: 25 calls/day. Sign up: https://www.alphavantage.co/support/#api-key
# ------------------------------------------------------------------
ALPHAVANTAGE_API_KEY=

# ------------------------------------------------------------------
# Anthropic (optional) — unlocks the AI Briefing tab (Claude Sonnet 4.6)
# Get a key: https://console.anthropic.com/
# Budget is protected by the settings below. See CLAUDE.md "Budget protection".
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Maximum USD spend on Anthropic API per calendar month (system local time).
# When this cap is reached, the Generate Briefing button is disabled until the
# 1st of next month OR until this value is manually raised in .env.
ANTHROPIC_MONTHLY_BUDGET_USD=5.00

# Minimum minutes between briefings. Default 60 (one per hour).
ANTHROPIC_MIN_MINUTES_BETWEEN_BRIEFINGS=60
